{
  "name": "prism",
  "version": "1.2.1",
  "description": "Prism spending tracker",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "electron .",
    "generate-icons": "node scripts/generate-icons.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.prism.app",
    "productName": "Prism",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "public/**/*",
      "!data/**/*",
      "!dist/**/*",
      "!bundle-public.js",
      "!public-bundle.js",
      "!scripts/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Prism-Setup.exe"
    },
    "dmg": {
      "title": "Prism",
      "artifactName": "Prism-${arch}.dmg"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "pkg": "^5.8.1"
  }
}
